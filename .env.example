# Copy this file to .env, then fill in your own values.
# Do not commit .env or share these secrets in chat.

# AWS CLI / local DVC access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1

# S3 bucket for DVC data and model artifacts.
# Bucket names must be globally unique, lowercase, and usually use hyphens.
AWS_S3_BUCKET=

# EC2 deployment values, fill after creating the VM.
VM_HOST=
VM_USER=ubuntu
VM_SSH_KEY_PATH=~/.ssh/mlops_deploy

# GitHub Actions repository secrets you will create later:
# AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY
# AWS_DEFAULT_REGION
# CLOUD_BUCKET
# VM_HOST
# VM_USER
# VM_SSH_KEY

# Optional bonus: DagsHub MLflow remote tracking.
# MLFLOW_TRACKING_URI should look like:
# https://dagshub.com/<dagshub-user>/<dagshub-repo>.mlflow
# MLFLOW_TRACKING_USERNAME is your DagsHub username.
# MLFLOW_TRACKING_PASSWORD is a DagsHub access token.
# MLFLOW_TRACKING_URI
# MLFLOW_TRACKING_USERNAME
# MLFLOW_TRACKING_PASSWORD
